CONFIG_SOC_SERIES_STM32F4X=y
CONFIG_SOC_STM32F405XG=y

# Clocks
CONFIG_CLOCK_CONTROL=y

# Console / UART
CONFIG_SERIAL=y
CONFIG_UART_INTERRUPT_DRIVEN=y

# Buses used by the app
CONFIG_GPIO=y
CONFIG_SPI=y
CONFIG_I2C=y
CONFIG_DMA=y

# FPU
CONFIG_FPU=y

# Enable MPU/flash defaults for the SoC
CONFIG_ARM_MPU=y
